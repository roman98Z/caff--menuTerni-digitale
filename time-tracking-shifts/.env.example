# PostgreSQL connection (use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/timetracking

# FastAPI
APP_NAME="Time Tracking & Shifts"
APP_DEBUG=false

# CORS (comma separated)
CORS_ORIGINS=*

# Rate limiting (requests per minute per IP, 0 = disabled)
RATE_LIMIT_PER_MINUTE=120

# Geo tolerance in meters for late/early detection (unused, reserved for future)
GEO_RADIUS_METERS=250
